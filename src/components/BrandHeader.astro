---
interface Props {
  reversed?: boolean;
}

const { reversed = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const homeUrl = `${base}/`;
const logo = reversed
  ? `${base}/assets/verran-labs-logo-horizontal-reversed.svg`
  : `${base}/assets/verran-labs-logo-horizontal.svg`;
---

<header class:list={["site-header", reversed && "site-header-dark"]}>
  <a class="brand-link" href={homeUrl} aria-label="Verran Labs home">
    <img src={logo} alt="Verran Labs" class="brand-logo" />
  </a>
  <nav class="site-nav" aria-label="Primary navigation">
    <a href="#services">Services</a>
    <a href="#contact">Contact</a>
  </nav>
</header>
