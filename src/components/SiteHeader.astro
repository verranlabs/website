---
import { publicAssetUrl, routes } from "../config/routes";

const logo = publicAssetUrl("assets/verran-labs-logo-horizontal-reversed.svg");
---

<header class="masthead">
  <a
    class="masthead-brand"
    href={routes.home}
    aria-label="Verran Labs home"
    data-preserve-attribution
  >
    <img src={logo} alt="Verran Labs" width="486" height="110" />
  </a>
  <nav class="masthead-nav" aria-label="Primary navigation">
    <a href={routes.home} data-preserve-attribution>Home</a>
    <a href={`${routes.home}#assessment`} data-preserve-attribution>Assessment</a>
    <a href={routes.agenticWorkspace} data-preserve-attribution>Workspace</a>
    <a href={routes.contact} data-preserve-attribution>Contact</a>
    <a href={routes.privacy} data-preserve-attribution>Privacy</a>
  </nav>
</header>
