---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { publicSiteConfig } from "../config/public";
import { routes } from "../config/routes";
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/home-offers.css";

const founderHeadshotUrl = publicSiteConfig.founderHeadshotUrl;
const linkedInUrl = publicSiteConfig.linkedInUrl;
---

<BaseLayout
  title="Private AI Systems for Sensitive Knowledge | Verran Labs"
  description="Verran Labs helps defense contractors and regulated technical teams assess, design, and deploy private AI and agentic RAG systems."
>
  <div class="marketing-page">
    <div class="enterprise-intro">
      <SiteHeader />

      <div>
        <section class="enterprise-hero">
          <div class="enterprise-hero-copy">
            <p class="marketing-eyebrow">Private AI systems for sensitive knowledge</p>
            <h1>Turn sensitive internal knowledge into a private AI system your team can trust.</h1>
            <p class="enterprise-lede">
              Verran Labs helps defense contractors and regulated technical teams assess,
              design, and deploy agentic RAG systems with clear security boundaries,
              measurable evaluation, and human control.
            </p>
            <div class="enterprise-actions">
              <a
                class="marketing-button marketing-button-primary"
                href={routes.assessmentContact}
                data-preserve-attribution
              >
                Request a Private AI System Assessment
              </a>
              <a
                class="marketing-button marketing-button-secondary"
                href={routes.workflowReviewContact}
                data-preserve-attribution
              >
                Explore the $2,500 Workflow Review
              </a>
            </div>
          </div>

          <aside class="boundary-map" aria-label="Private AI system boundaries">
            <p class="boundary-map-label">A controlled production path</p>
            <ol>
              <li>
                <span>01</span>
                <div><strong>Approved knowledge</strong><small>Sources and sensitivity mapped</small></div>
              </li>
              <li>
                <span>02</span>
                <div><strong>Retrieval and evaluation</strong><small>Quality measured before scale</small></div>
              </li>
              <li>
                <span>03</span>
                <div><strong>Bounded agent actions</strong><small>Human approval where mistakes cost</small></div>
              </li>
            </ol>
            <p class="boundary-map-note">Ownership option ≠ automatic privacy</p>
          </aside>
        </section>
      </div>
    </div>

    <main id="main-content" class="enterprise-main" tabindex="-1">
      <section class="buyer-fit" aria-labelledby="buyer-fit-title">
        <div>
          <p class="marketing-kicker">When the system is stuck</p>
          <h2 id="buyer-fit-title">Move from a promising prototype to a defensible production decision.</h2>
        </div>
        <ul class="buyer-fit-list">
          <li>Sensitive knowledge cannot move into an unmanaged tool.</li>
          <li>Retrieval quality is demonstrated, but not measured.</li>
          <li>Agent permissions and human approvals are still undefined.</li>
          <li>The team cannot yet defend hosting, security, or operating tradeoffs.</li>
        </ul>
      </section>

      <section
        id="assessment"
        class="assessment-section"
        aria-labelledby="assessment-title"
      >
        <div class="assessment-heading">
          <p class="marketing-kicker">Primary engagement · 2–4 weeks</p>
          <h2 id="assessment-title">Private AI System Assessment</h2>
          <p>
            A custom-scoped decision engagement for an active private-AI, RAG, or
            sensitive-knowledge problem. The outcome is a credible architecture and
            implementation path—not another open-ended discovery exercise.
          </p>
          <div class="assessment-meta">
            <span>Custom scoped</span>
            <span>One focused system</span>
            <span>Decision-ready roadmap</span>
          </div>
        </div>

        <div class="deliverable-grid">
          <article><span>01</span><h3>Knowledge-source and workflow map</h3><p>Define approved inputs, users, decisions, and operational handoffs.</p></article>
          <article><span>02</span><h3>Model and deployment recommendation</h3><p>Compare managed, private-endpoint, and self-hosted options against the real constraints.</p></article>
          <article><span>03</span><h3>Retrieval and bounded-agent architecture</h3><p>Specify retrieval, tool permissions, human review, and failure boundaries.</p></article>
          <article><span>04</span><h3>Security and approval boundaries</h3><p>Make data flow, access, escalation, and ownership assumptions explicit.</p></article>
          <article><span>05</span><h3>Evaluation plan</h3><p>Define retrieval, answer-quality, refusal, and regression checks before scaling.</p></article>
          <article><span>06</span><h3>Risks, dependencies, and roadmap</h3><p>Leave with sequenced decisions, build milestones, and known procurement constraints.</p></article>
        </div>
      </section>

      <section
        id="workflow-review"
        class="workflow-review-section"
        aria-labelledby="workflow-review-title"
      >
        <div class="workflow-review-heading">
          <p class="marketing-kicker">For smaller teams · Fixed scope</p>
          <h2 id="workflow-review-title">AI Workflow Review</h2>
          <p class="workflow-review-price"><strong>$2,500</strong> fixed price</p>
          <p>
            Bring one workflow or AI idea that needs a credible decision before your
            team commits to a larger build. The review turns one focused working
            session into a written, decision-ready recommendation.
          </p>
        </div>

        <div class="workflow-review-details">
          <article>
            <span>Working session</span>
            <h3>Includes one 60–90 minute working session</h3>
            <p>Map the goal, current process, available inputs, constraints, and decision boundary.</p>
          </article>
          <article>
            <span>Written outcome</span>
            <h3>A recommendation your team can act on</h3>
            <ul>
              <li>Feasibility recommendation</li>
              <li>Architecture recommendation</li>
              <li>Risk recommendation</li>
              <li>Next-step recommendation</li>
            </ul>
          </article>
        </div>

        <div class="workflow-review-boundary">
          <p>
            <strong>Implementation is not included.</strong> Additional sources,
            workflows, integrations, travel, implementation, and ongoing support are
            separate scope.
          </p>
          <a
            class="marketing-button marketing-button-primary"
            href={routes.workflowReviewContact}
            data-preserve-attribution
          >
            Request the Workflow Review
          </a>
        </div>
      </section>

      <section class="system-evidence" aria-labelledby="system-evidence-title">
        <div class="system-evidence-copy">
          <p class="marketing-kicker">System evidence</p>
          <h2 id="system-evidence-title">Architecture before autonomy.</h2>
          <p>
            A useful agentic RAG system is more than search plus chat. It connects
            controlled ingestion, retrieval, model routing, tool permissions,
            evaluation, observability, and human control into one operating design.
          </p>
          <ul>
            <li>Security boundaries are documented, not implied.</li>
            <li>Evaluation is part of the system, not a launch-week add-on.</li>
            <li>Self-hosting remains an option—not a guarantee.</li>
          </ul>
        </div>
        <figure class="architecture-visual" aria-label="Private AI system architecture">
          <ol class="architecture-flow" aria-label="Controlled system path">
            <li><span>01</span><strong>Approved sources</strong><small>Named data boundary</small></li>
            <li><span>02</span><strong>Controlled ingestion</strong><small>Parse, normalize, trace</small></li>
            <li><span>03</span><strong>Retrieval</strong><small>Evidence with citations</small></li>
            <li><span>04</span><strong>Model boundary</strong><small>Chosen for the constraints</small></li>
            <li><span>05</span><strong>Bounded actions</strong><small>Explicit tools and permissions</small></li>
          </ol>
          <div class="architecture-controls" aria-label="Operating controls">
            <div><span>Human approval</span><small>Review before consequential action</small></div>
            <div><span>Evaluation feedback</span><small>Quality, refusal, and regression checks</small></div>
          </div>
          <figcaption>Representative private-AI system pattern; final architecture follows the assessment.</figcaption>
        </figure>
      </section>

      <section class="workspace-path" aria-labelledby="workspace-path-title">
        <div>
          <p class="marketing-kicker">For individual knowledge workers</p>
          <h2 id="workspace-path-title">Private Agentic Workspace</h2>
          <p>
            A focused, done-with-you workspace for technical founders, independent
            consultants, researchers, and executives who want to work more effectively
            with their own approved knowledge.
          </p>
        </div>
        <aside aria-label="Private Agentic Workspace price and action">
          <span>$4,500 fixed price</span>
          <p>Up to two approved knowledge sources and one bounded workflow.</p>
          <a
            class="marketing-button marketing-button-primary"
            href={routes.agenticWorkspace}
            data-preserve-attribution
          >
            Explore the Private Agentic Workspace
          </a>
        </aside>
      </section>

      <section
        class="founder-boundary"
        aria-label="Founder-led delivery"
      >
        <div class="founder-profile">
          {
            founderHeadshotUrl ? (
              <img
                class="founder-headshot"
                src={founderHeadshotUrl}
                alt="Joseph Tabalon Jr., founder of Verran Labs"
                width="640"
                height="800"
                loading="lazy"
              />
            ) : (
              <div class="founder-photo-pending" aria-hidden="true">
                <span>Founder profile</span>
                <strong>Photography held until supplied and verified.</strong>
              </div>
            )
          }
          <div>
            <p class="marketing-kicker">Founder-led delivery</p>
            <h2 id="founder-title">Built and led by Joseph Tabalon Jr.</h2>
            <p class="founder-lede">
              Joseph Tabalon Jr. leads and participates directly in every engagement,
              bringing hands-on experience across defense cyber RAG and NLP, secure
              container and AWS deployment, production data pipelines, evaluation,
              and computer-vision inspection systems.
            </p>
            {
              linkedInUrl && (
                <a
                  class="founder-link"
                  href={linkedInUrl}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  View Joseph on LinkedIn
                </a>
              )
            }
            {
              !founderHeadshotUrl && !linkedInUrl ? (
                <p class="founder-proof-status">
                  Professional headshot and LinkedIn profile pending launch verification.
                </p>
              ) : (
                <>
                  {!founderHeadshotUrl && <p class="founder-proof-status">Professional headshot pending launch verification.</p>}
                  {!linkedInUrl && <p class="founder-proof-status">LinkedIn profile pending launch verification.</p>}
                </>
              )
            }
          </div>
        </div>
        <aside class="claims-note" aria-label="Company credential boundary">
          <strong>Claims boundary</strong>
          <p>
            Joseph has experience in cleared and secure government environments.
            Verran Labs does not claim company clearance or certification, and does
            not promise that any deployment pattern is automatically secure or compliant.
          </p>
        </aside>
      </section>

      <section class="selected-experience" aria-labelledby="selected-experience-title">
        <div class="selected-experience-heading">
          <p class="marketing-kicker">Claims-safe proof</p>
          <h2 id="selected-experience-title">Selected Experience</h2>
          <p>
            Anonymized areas from Joseph’s prior work—not Verran Labs client case studies.
            Planned demonstrations are not presented as completed work. No client identities,
            protected program details, or invented metrics are presented.
          </p>
        </div>
        <div class="experience-grid">
          <article><span>01</span><h3>DoD cyber RAG and NLP</h3><p>Retrieval, enrichment, and analyst-support workflows for sensitive technical knowledge.</p></article>
          <article><span>02</span><h3>Secure container and AWS deployment</h3><p>Containerized delivery and cloud deployment work in environments with explicit operating boundaries.</p></article>
          <article><span>03</span><h3>Production data ingestion and evaluation</h3><p>Repeatable ingestion pipelines and evaluation practices that support production decisions.</p></article>
          <article><span>04</span><h3>Computer-vision inspection and imaging</h3><p>Inspection and imaging workflows that keep human review in the operating loop.</p></article>
        </div>
      </section>

      <section class="capacity-panel" aria-labelledby="capacity-title">
        <div>
          <p class="marketing-kicker">Focused capacity</p>
          <h2 id="capacity-title">Start with one decision that matters.</h2>
          <p>
            Verran Labs accepts a limited number of focused engagements. Start dates
            are confirmed after scope, security requirements, and current capacity are reviewed.
          </p>
        </div>
        <a
          class="marketing-button marketing-button-primary"
          href={routes.assessmentContact}
          data-preserve-attribution
        >
          Request an assessment
        </a>
      </section>
    </main>

    <SiteFooter />
  </div>
</BaseLayout>
