---
import LandingPrototype from "../components/LandingPrototype.astro";
import { getPrototype } from "../data/prototypes";
import BaseLayout from "../layouts/BaseLayout.astro";

const prototype = getPrototype("agentic-rag");

if (!prototype) {
  throw new Error("The selected Agentic RAG homepage is missing.");
}
---

<BaseLayout
  title="Agentic RAG and Private AI Systems | Verran Labs"
  description="Verran Labs builds agentic RAG and private AI systems that technical teams can own, evaluate, and improve."
>
  <LandingPrototype prototype={prototype} />
</BaseLayout>
