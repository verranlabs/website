# Public integration identifiers. Leave unset until the matching service is ready.
PUBLIC_TALLY_FORM_ID=
PUBLIC_BOOKING_URL=
PUBLIC_LINKEDIN_URL=
PUBLIC_FOUNDER_HEADSHOT_URL=
# Public 32-character site token from the Cloudflare Web Analytics snippet.
# Do not use a Cloudflare API token, API key, or other credential here.
PUBLIC_CLOUDFLARE_ANALYTICS_BEACON=

# The deployed site root, including a path prefix when one exists.
# Indexing stays disabled unless both this value and PUBLIC_SITE_INDEXING=enabled are set.
PUBLIC_SITE_ORIGIN=
PUBLIC_SITE_INDEXING=disabled
